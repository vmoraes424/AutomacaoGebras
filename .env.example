# Copie para .env e preencha apenas segredos e flags de ambiente.
# IDs Plune e URLs: core/gebras_defaults.py
# Estado e catálogo: MySQL (database dedicado, não usar o gebras principal)

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=gebras_automacao
# Tabela automacao_config (flags do portal) — editável em /config/automacao
# Banco operacional do SOLE HUB (pedido, instalacao, etc.)
MYSQL_DATABASE_HUB=gebras

# Usuario sistema no HUB para INSERT de pedido (padrao: -3 = AUTOMACAO)
HUB_CODIGO_USUARIO_SISTEMA=-3

PIPEDRIVE_API_TOKEN=

CLICKSIGN_ACCESS_TOKEN=
CLICKSIGN_WEBHOOK_URL=

PLUNE_AUTH_TOKEN=

# E-mail informativo comercial (etapa 1) — Microsoft Graph (igual Automação CCEE)
tenant_id=
client_id=
client_secret=
email=

# --- Portal / automação ---
# Flags dev/prod: portal → /config/automacao (tabela automacao_config no MYSQL_DATABASE)
# Senha da tela de configs (vazio = aberta; preenchido = exige senha no portal)
PORTAL_CONFIG_PASSWORD=

# Token de acesso à API do portal (vazio = sem auth, só dev/rede interna)
PORTAL_API_TOKEN=

# mysql (produção) ou memory (testes locais sem MySQL)
PORTAL_DEAL_FORM_REPOSITORY=mysql

# Logs HTTP em JSON no stdout da API
PORTAL_STRUCTURED_LOGS=true

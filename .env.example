# Copie para .env e preencha os valores

PIPEDRIVE_API_TOKEN=

CLICKSIGN_ACCESS_TOKEN=
CLICKSIGN_BASE_URL=https://app.clicksign.com/api/v3
CLICKSIGN_WEBHOOK_URL=
CLICKSIGN_RATE_LIMIT_MAX_RETRIES=12
CLICKSIGN_RATE_LIMIT_BUFFER_SEC=1
# true = não chama Clicksign (só gera .docx; útil em dev para evitar rate limit). Combinar com TESTE_PLUNE_SEM_ASSINATURA para Plune.
DEV_PULAR_CLICKSIGN=false

PLUNE_BASE_URL=https://www-gebras.plune.com.br
PLUNE_AUTH_TOKEN=
PLUNE_COMPANY_ID=869
PLUNE_BRANCH_ID=751
PLUNE_TIPO_OP_ID=20
PLUNE_STATUS_PEDIDO=32
PLUNE_TIPO_CONTRATO_ID=3
# Centro = CONTRATOS COMERCIAIS
PLUNE_CENTRO_CUSTO_ID=5
# Sub Centro = GESTAO DE ENERGIA.
# Branch 751 (Matriz): 447. Branch 790 (ISM): 449.
PLUNE_SUBCENTRO_CUSTO_ID=
PLUNE_PRODUTO_SOLE_ID=5584
PLUNE_PARCEIRO_TIPO=cliente
PLUNE_STATUS_PEDIDO_IMPLANTACAO_ID=31
PLUNE_STATUS_PEDIDO_RECORRENTE_ID=33
PLUNE_FRETE_POR_CONTA=9
# Mapeia REGIONAL do Pipedrive para Venda.Pedido.SubCentroCusto2Id no Plune,
# depois de Centro=Contratos Comerciais e Sub Centro=Gestao de Energia.
# Branch 751 (Matriz): {"Regional 1":"26","Regional2":"27","Regional3":"28","Sede":"29"}
# Branch 790 (ISM): {"Regional 1":"33","Regional2":"34","Regional3":"35","Sede":"36"}
PLUNE_REGIONAL_SUBCENTRO2_MAP={}
# Parametros contabeis dependem da filial:
# Branch 751 (Matriz): recorrente=1077, implantacao=1440.
# Branch 790 (ISM): recorrente=1102, implantacao=1436.
PLUNE_PARAMETRO_CONTABIL_RECORRENTE_ID=1077
PLUNE_PARAMETRO_CONTABIL_IMPLANTACAO_ID=1440

INTERVALO_POLLING_SEGUNDOS=30
MODELO_DOCX=contrato_padrao.docx
PASTA_SAIDA=./contratos
TESTE_PLUNE_SEM_ASSINATURA=true
ARQUIVO_DEALS_PROCESSADOS=runtime/state/deals_processados.txt
ARQUIVO_ENVELOPES_PENDENTES=runtime/state/envelopes_pendentes.json
ARQUIVO_PEDIDOS_PLUNE_CRIADOS=runtime/state/pedidos_plune_criados.txt
ARQUIVO_AVISOS_APROVACAO_PLUNE=runtime/state/avisos_aprovacao_plune.txt

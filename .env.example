# Copie para .env e preencha apenas segredos e flags de ambiente.
# IDs Plune e URLs: core/gebras_defaults.py
# Estado e catálogo: MySQL (database dedicado, não usar o gebras principal)

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=gebras_automacao
# Banco operacional do SOLE HUB (pedido, instalacao, etc.)
MYSQL_DATABASE_HUB=gebras

# Usuario sistema no HUB para INSERT de pedido (padrao: -3 = AUTOMACAO)
HUB_CODIGO_USUARIO_SISTEMA=-3

PIPEDRIVE_API_TOKEN=

CLICKSIGN_ACCESS_TOKEN=
CLICKSIGN_WEBHOOK_URL=

PLUNE_AUTH_TOKEN=

# E-mail informativo comercial (etapa 1) — Microsoft Graph (igual Automação CCEE)
tenant_id=
client_id=
client_secret=
email=

# true = não chama Clicksign (útil em dev; combine com TESTE_PLUNE_SEM_ASSINATURA)
DEV_PULAR_CLICKSIGN=false

# true = cria pedido Plune sem esperar assinatura Clicksign
TESTE_PLUNE_SEM_ASSINATURA=true

# true = cria pedido no HUB após Plune no ganho (dev), sem aprovação Plune pós-assinatura
DEV_HUB_SEM_APROVACAO_PLUNE=false

# true = não cria pedido no HUB (atualizações e validações continuam)
PULAR_HUB=false
